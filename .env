# /docker/nexuscloud/.env
# NexusCloud Environment Variables

# App Configuration
APP_URL=http://187.77.183.14:3000
API_URL=http://187.77.183.14:3000

# Security (GENERATE THESE WITH openssl rand -hex 32)
JWT_SECRET=$(openssl rand -hex 32)
SESSION_SECRET=$(openssl rand -hex 32)

# Redis (optional password)
REDIS_PASSWORD=your_strong_redis_password_here

# Database (if using PostgreSQL)
DB_USER=nexuscloud
DB_PASSWORD=your_strong_db_password_here

# CORS (for production, set specific domains)
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# File Upload
MAX_FILE_SIZE=104857600
ALLOWED_MIME_TYPES=image/*,application/pdf,text/*,application/msword

# Logging
LOG_LEVEL=info